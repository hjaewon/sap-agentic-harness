+/**
+ * [powerup 4.13.9] Honour the ADT deletion service's del:isDeleted flag.
+ *
+ * The generic `POST /sap/bc/adt/deletion/delete` service returns HTTP 200 even
+ * when it REFUSES the delete (e.g. the object is still locked): the real
+ * outcome is carried only by `del:deletionResult/del:object[@del:isDeleted]`
+ * plus an E-level `del:message`. The vendored low-level `deleteX()` helpers
+ * historically discarded that body and hardcoded `{ success: true }`, so a
+ * failed delete was reported to the caller as a success (HANDOFF §6 backlog
+ * 3-5, live-measured on DeleteFunctionGroup). This asserts the flag and throws
+ * with the SAP message on a POSITIVELY-identified failure. Unknown / absent
+ * deletionResult bodies fall back to the HTTP status only, so an unusual but
+ * successful response shape is never mis-reported as a failure. Mirrors the
+ * parse the vendored `deletePackage()` already performs.
+ *
+ * @param response - the raw axios response from the deletion POST
+ * @param objectLabel - human label for the error message (e.g. 'Function group')
+ */
+function assertDeletionSucceeded(response, objectLabel) {
+    const label = objectLabel || 'Object';
+    const data = response && response.data;
+    if (typeof data === 'string' && data.indexOf('deletionResult') !== -1) {
+        try {
+            const { XMLParser } = require('fast-xml-parser');
+            const parser = new XMLParser({
+                ignoreAttributes: false,
+                attributeNamePrefix: '@_',
+            });
+            const result = parser.parse(data);
+            let deleteObjects = result['del:deletionResult']?.['del:object'] ??
+                result.deletionResult?.object;
+            if (deleteObjects) {
+                // A single delete can cascade into several del:object entries
+                // (e.g. a structure returns both its TABL/DS and TABT/DTT
+                // nodes), and fast-xml-parser yields an ARRAY in that case.
+                // Every node must report isDeleted="true" for the delete to
+                // have succeeded; any node with isDeleted!="true" is a failure.
+                if (!Array.isArray(deleteObjects)) {
+                    deleteObjects = [deleteObjects];
+                }
+                for (const obj of deleteObjects) {
+                    const isDeleted = obj['@_del:isDeleted'] === 'true' ||
+                        obj['@_isDeleted'] === 'true';
+                    if (!isDeleted) {
+                        let text = obj['del:message']?.['del:text'] ??
+                            obj.message?.text;
+                        if (text && typeof text === 'object') {
+                            text = text['#text'] ?? '';
+                        }
+                        const msg = typeof text === 'string' && text.trim()
+                            ? text.trim()
+                            : 'the deletion service reported isDeleted="false"';
+                        throw new Error(`${label} deletion failed: ${msg}`);
+                    }
+                }
+            }
+        }
+        catch (error) {
+            if (error &&
+                typeof error.message === 'string' &&
+                error.message.includes('deletion failed')) {
+                throw error;
+            }
+            // Parse hiccup on a body that mentioned deletionResult but did not
+            // parse cleanly — fall through to the HTTP-status check below.
+        }
+    }
+    if (response &&
+        typeof response.status === 'number' &&
+        response.status >= 400) {
+        throw new Error(`${label} deletion failed: HTTP ${response.status} ${response.statusText || ''}`.trim());
+    }
+}
