# Test Configuration for @mcp-abap-adt integration tests
#
# Usage:
#   cp tests/test-config.yaml.template tests/test-config.yaml
#   # Edit ONLY the lines marked with "# ← CHANGE" below
#
# ┌──────────────────────────────────────────────────────────────────┐
# │  REQUIRED CHANGES (edit these after copying):                    │
# │                                                                  │
# │  1. environment.env                — session .env file name      │
# │  2. environment.system_type        — "onprem"/"cloud"/"legacy"   │
# │  3. environment.default_package    — your dev package (Z*/Y*)    │
# │  4. environment.default_transport  — transport request or ""     │
# │  5. shared_dependencies.package    — package for shared objects  │
# │  6. shared_dependencies.software_component — "ZLOCAL"/"HOME"    │
# │                                                                  │
# │  OPTIONAL (cloud/BTP, JWT token refresh):                        │
# │  7. auth_broker.abap.destination   — auth broker destination     │
# └──────────────────────────────────────────────────────────────────┘
#
# IMPORTANT: Object Naming Convention
# ===================================
# All test objects must use the ZMCP_BLD_* naming convention:
# - Classes: ZMCP_BLD_CLS01, ZMCP_BLD_CLS02, etc.
# - Domains: ZMCP_BLD_DOM01, ZMCP_BLD_DOM02, etc.
# - Data Elements: ZMCP_BLD_DTEL01, ZMCP_BLD_DTEL_H2, etc.
# - Function Modules: Z_MCP_BLD_FM01, Z_MCP_BLD_FM02, etc. (must start with Z_ or Y_)
# - Function Groups: ZMCP_BLD_FGR01, ZMCP_BLD_FGR02, etc.
# - Interfaces: ZMCP_BLD_IF01, ZMCP_BLD_IF02, etc.
# - Programs: ZMCP_BLD_PROG_H1, ZMCP_BLD_PROG02, etc.
# - Tables: ZMCP_BLD_TAB01, ZMCP_BLD_TAB_H1, etc.
# - Structures: ZMCP_BLD_STRU_H1, ZMCP_BLD_STRU02, etc.
# - Views: ZMCP_BLD_VIEW01, ZMCP_BLD_VIEW_H1, etc.
# - Packages: ZMCP_BLD_PKG01, ZMCP_BLD_PKG02, etc.
#
# Test settings

# ============================================================================
# GLOBAL CONFIGURATION
# ============================================================================

test_settings:
  fail_fast: false
  verbose: true
  timeout: 120000  # Global test timeout (120 seconds)
  retry_on_failure: false
  max_retries: 1
  cleanup_after_test: false
  # Timeouts for different operations (in milliseconds)
  timeouts:
    default: 120000
    long: 400000  # Long timeout for complex operations (group deletion, etc.)
    create: 120000
    test: 120000
    delay: 3000  # Delay after delete/create operations
  # Operation delays (milliseconds) - time to wait for SAP to commit operations
  # These delays ensure SAP has time to persist state changes between operations
  operation_delays:
    lock: 3000      # Delay after lock operation (default: 3 seconds)
    unlock: 3000    # Delay after unlock operation (default: 3 seconds)
    update: 3000    # Delay after update operation (default: 3 seconds)
    create: 3000    # Delay after create operation (default: 3 seconds)
    cleanup: 3000   # Delay after pre-test cleanup (delete) before test starts
    default: 3000   # Default delay for any operation (default: 3 seconds)

# Session persistence configuration

session_config:
  # Enable session persistence (saves cookies and CSRF tokens)
  persist_session: true
  # Directory for session files (relative to project root)
  sessions_dir: ".sessions"
  # Session ID format: {test_name}_{timestamp} or custom
  session_id_format: "auto"  # "auto" or custom string
  # Clean up session after test
  cleanup_session_after_test: true

# Lock persistence configuration

lock_config:
  # Directory for lock files (relative to project root)
  locks_dir: ".locks"
  # Track locks in persistent storage
  persist_locks: true

# Environment configuration

environment:
  # Connection: .env file from standard sessions folder (~/Documents/mcp-abap-adt/sessions/)
  # Contains SAP_URL, SAP_USERNAME, SAP_PASSWORD, SAP_CLIENT, SAP_AUTH_TYPE, etc.
  env: ""                                    # ← CHANGE: session file name (e.g., "e19.env", "mdd.env")
  # System and connection type (explicit, no auto-detection)
  system_type: ""                            # ← CHANGE: "onprem" | "cloud" | "legacy"
  connection_type: "http"                    # "http" | "rfc" (rfc for legacy, BASIS < 7.50)
  # Test defaults
  default_package: "ZMCP_TEST"              # ← CHANGE: your dev package (Z*/Y*) or "$TMP" for local
  default_transport: ""                       # ← CHANGE: transport request (leave "" for $TMP/local packages)
  cleanup_after: true                        # Clean up objects after test
  # Real MCP client mode — tests go through full MCP transport layer
  integration_hard_mode:
    enabled: false
    transport: "stdio"
    mcp_destination: ""                      # MCP destination (optional, for hard mode)

# RFC backend parity — validates that SAP_RFC_BACKEND=soap and =native
# produce equivalent results against the same SAP system. Exercised by
# src/__tests__/integration/rfc-backend/RfcBackendParity.test.ts.
#
# Leave backends=['soap'] on CI hosts without the NW RFC SDK. Adding
# 'native' requires:
#   • SAP NW RFC SDK 7.50+ installed on this host
#   • SAPNWRFC_HOME env var pointing to the extracted SDK
#   • `npm rebuild node-rfc` succeeds
#   • The SAP_RFC_* block below populated (mirrors .sc4sap/sap.env)
#
# If a backend is listed but its preconditions fail, the parity test
# logs and skips that backend — it does NOT fail the suite.
rfc_backend:
  enabled: true                              # Master switch for the parity suite
  backends: ["soap"]                         # ← CHANGE to ["soap", "native"] when native is ready
  probe_program: "RSPARAM"                   # Standard SAP program guaranteed to exist; used for TEXTPOOL READ parity
  probe_language: "EN"
  native:                                    # Only read when 'native' is in backends[]
    ashost: ""                               # e.g. "s4h.example.com"   (mutually exclusive with mshost)
    sysnr: ""                                # e.g. "00"
    mshost: ""                               # e.g. "msrv.example.com"  (leave blank if using ashost)
    sysid: ""                                # e.g. "S4H"               (required when mshost is set)
    group: "PUBLIC"
    client: ""                               # 3-digit, usually same as SAP_CLIENT
    user: ""                                 # Dedicated RFC user with S_RFC auth recommended
    passwd: ""                               # ⚠️ plain text in local config — do not commit
    lang: "EN"

# ============================================================================
# SHARED DEPENDENCIES — persistent Lego library for integration tests
# ============================================================================
# Objects are lazily created on first ensureSharedDependency() call, never deleted.
# Manage with: npm run shared:setup / shared:teardown / shared:check

shared_dependencies:
  package: "ZMCP_SHARED"                   # ← CHANGE: package for shared test objects
  super_package: ""                          # super package (optional, leave "" if none)
  software_component: "ZLOCAL"               # ← CHANGE: "ZLOCAL" for cloud, "LOCAL"/"HOME" for onprem
  transport_layer: ""

  tables:
    - name: "ZMCP_SHR_RTABL"
      description: "Shared table for root CDS entity"
      available_in: ["onprem", "cloud"]
      source: |
        @EndUserText.label : 'Shared table for root CDS entity'
        @AbapCatalog.enhancement.category : #NOT_EXTENSIBLE
        @AbapCatalog.tableCategory : #TRANSPARENT
        @AbapCatalog.deliveryClass : #A
        @AbapCatalog.dataMaintenance : #RESTRICTED
        define table zmcp_shr_rtabl {
          key client : abap.clnt not null;
          key fld1   : abap.char(10) not null;
          fld2       : abap.char(50);
          fld3       : abap.dec(10,2);
          fld4       : abap.dats;
        }

    - name: "ZMCP_SHR_CTABL"
