  test_cases:
    - name: "test_runtime_readonly"
      enabled: true
      available_in: ["onprem", "cloud"]
      description: "Runtime profiling and dumps handlers integration tests"
      params:
        # Class for profiled execution (must support ADT classrun endpoint)
        profiled_class_name: "ZMCP_BLD_CLSLOC_H1"
        # Prefix for temporary class created by profiling test
        profiled_class_prefix: "ZMCP_RTCLS"
        # On-prem only: executable report for RuntimeRunProgramWithProfiling
        profiled_program_name: "ZMCP_BLD_PROG023"
        # Prefix for temporary program created by profiling test (on-prem only)
        profiled_program_prefix: "ZMCP_RTPRG"
        # Optional fallback trace id/uri when feed parsing does not provide one
        trace_id_or_uri: ""
        # Retries for trace files feed lookup (trace can appear with delay)
        trace_feed_retries: 6
        trace_feed_retry_delay_ms: 1000
        # Retries for reading profiler trace data (trace can appear with delay)
        trace_read_retries: 6
        trace_read_retry_delay_ms: 1500
        # Optional user filter for dumps list (empty = all users)
        dumps_user: ""
        # Number of dump IDs to read from feed
        dumps_read_limit: 5
        # Prefix for temporary class that forces runtime dump (division by zero)
        dump_class_prefix: "ZMCP_RTDMP"
        # Retries for dump feed lookup after forced failure
        dump_feed_retries: 8
        dump_feed_retry_delay_ms: 1500
        # How many recent dumps to request per poll when looking for generated dump
        dump_feed_top: 50
        # Dump read view for RuntimeGetDumpById/RuntimeAnalyzeDump: default|summary|formatted
        dump_view: "default"
        # Optional fallback dump ID when feed parsing does not provide one
        dump_id: ""

