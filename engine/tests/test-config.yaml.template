  behavior_definitions:
    - name: "ZMCP_SHR_I_ROOT"
      description: "Shared BDEF for BehaviorDefinition and BehaviorImplementation tests"
      available_in: ["onprem", "cloud"]
      root_entity: "ZMCP_SHR_I_ROOT"
      implementation_type: "Managed"
      source: |
        managed implementation in class zbp_mcp_shr_i_root unique;
        strict ( 2 );

        define behavior for ZMCP_SHR_I_ROOT
        persistent table zmcp_shr_rtabl
        lock master
        authorization master ( instance )
        {
          create ( authorization : global );
          update;
          delete;
          field ( readonly ) Fld1;
          association _children { create; }
        }

        define behavior for ZMCP_SHR_I_CHLD
        persistent table zmcp_shr_ctabl
        lock dependent by _parent
        authorization dependent by _parent
        {
          update;
          delete;
          field ( readonly:update ) ChldId, ParentId;
          association _parent;
        }

  classes:
    - name: "ZBP_MCP_SHR_I_ROOT"
      description: "Shared BDEF implementation class for ZMCP_SHR_I_ROOT"
      available_in: ["onprem", "cloud"]
    - name: "ZMCP_BLD_CLSUT_L1"
      description: "Shared container class for unit test integration tests"
      available_in: ["onprem", "cloud", "legacy"]

  function_groups:
    - name: "ZMCP_BLD_SHR_FGR"
      description: "Shared function group for read tests"
      available_in: ["onprem", "cloud", "legacy"]

  function_modules:
    - name: "Z_MCP_BLD_SHR_FM"
      group: "ZMCP_BLD_SHR_FGR"
      description: "Shared function module for read tests"
      available_in: ["onprem", "cloud", "legacy"]
      source: |
        FUNCTION Z_MCP_BLD_SHR_FM
            IMPORTING
               VALUE(IV_INPUT) TYPE  STRING
            EXPORTING
               VALUE(EV_OUTPUT) TYPE  STRING.
          ev_output = |Echo: { iv_input }|.
        ENDFUNCTION.

# Legacy shared_objects (kept for backward compatibility with unit_test_class)
shared_objects:
  unit_test_class:
    class_name: "ZMCP_BLD_CLSUT_L1"
    # package_name: "ZMCP_SHR_PKG"  # Uses environment.default_package if omitted
    transport_request: ""
    description: "Shared container class for unit test integration tests"

# ============================================================================
# AUTHENTICATION BROKER CONFIGURATION
# ============================================================================
# Configuration for AuthBroker-based token refresh before integration tests
# This allows tests to automatically refresh expired tokens using AuthBroker
# instead of relying solely on refresh tokens from .env file

auth_broker:
  # Use file-based session store (unsafe) to reuse saved sessions for tests (set MCP_UNSAFE=true)
  unsafe: true
  # Browser auth callback port (default 3001). Change if port is busy.
  browser_auth_port: 3101
  # Paths configuration (applies to both ABAP and BTP/XSUAA)
  paths:
    # Base directory for auth broker storage
    # This is a BASE path - the system will automatically create service-keys/ and sessions/ subdirectories inside it
    # Service key files: <base_path>/service-keys/<destination>.json (e.g., TRIAL.json, mcp.json)
    # Session files: <base_path>/sessions/<destination>.env (e.g., TRIAL.env, mcp.env)
    # If not specified, uses default: ~/.config/mcp-abap-adt/ (Unix) or %USERPROFILE%\Documents\mcp-abap-adt\ (Windows)
    # Supports ~ (home directory) expansion
    # ⚠️ IMPORTANT: This is a BASE path, not the service-keys or sessions directory itself!
    # Example: ~/.config/mcp-abap-adt will create:
    #   - ~/.config/mcp-abap-adt/service-keys/<destination>.json
    #   - ~/.config/mcp-abap-adt/sessions/<destination>.env
    service_keys_dir: "~/.config/mcp-abap-adt"  # Base path for service keys and sessions

  # ABAP destination configuration (for on-premise or cloud ABAP systems)
  abap:
    # ABAP destination name (used for service key file: <destination>.json and session file: <destination>.env)
    # Example: "TRIAL" -> looks for TRIAL.json in service-keys directory and TRIAL.env in sessions directory
    # This destination is used by refreshTokensForTests() to automatically refresh tokens before integration tests
    # If not specified, token refresh will be skipped and tests will use tokens from .env file
    destination: ""                    # Auth broker destination (cloud/BTP only, e.g. "TRIAL", "mcp")

# ============================================================================
# OBJECT TESTS (High-Level, then Low-Level for each object)
# ============================================================================

# Behavior Definition (Behavior Definition - Low-Level)
# Uses fully isolated shared CDS views ZMCP_SHR_I_BDFL/BCHL with own tables
create_behavior_definition_low:
  test_cases:
    - name: "full_workflow"
      enabled: true
      available_in: ["onprem", "cloud"]
      description: "Behavior Definition low-level handler full workflow test"
      params:
        name: "ZMCP_SHR_I_BDFL"
        description: "Behavior Definition low-level handler test"
        root_entity: "ZMCP_SHR_I_BDFL"
        implementation_type: "Managed"
        source_code: |
          managed implementation in class zbp_mcp_shr_i_bdfl unique;
          strict ( 2 );

          define behavior for ZMCP_SHR_I_BDFL
          persistent table zmcp_shr_bltbl
          lock master
          authorization master ( instance )
          {
            create ( authorization : global );
            update;
            delete;
            field ( readonly ) Fld1;
            association _children { create; }
          }

          define behavior for ZMCP_SHR_I_BCHL
          persistent table zmcp_shr_blctl
          lock dependent by _parent
          authorization dependent by _parent
          {
            update;
            delete;
            field ( readonly:update ) ChldId, ParentId;
            association _parent;
          }
        update_source_code: |
          managed implementation in class zbp_mcp_shr_i_bdfl unique;
          strict ( 2 );

          define behavior for ZMCP_SHR_I_BDFL
          persistent table zmcp_shr_bltbl
          lock master
          authorization master ( instance )
          {
            create ( authorization : global );
            update;
            delete;
            field ( readonly ) Fld1;
            field ( readonly ) Fld2;
            association _children { create; }
          }

          define behavior for ZMCP_SHR_I_BCHL
          persistent table zmcp_shr_blctl
          lock dependent by _parent
          authorization dependent by _parent
          {
            update;
            delete;
            field ( readonly:update ) ChldId, ParentId;
            association _parent;
          }

# Behavior Implementation (Behavior Implementation - High-Level)
# Used in combined BDEF+BIMPL test — BDEF (ZMCP_SHR_I_BDEF) is created first in the same test
create_behavior_implementation:
  test_cases:
    - name: "builder_behavior_implementation"
      enabled: true
      available_in: ["onprem", "cloud"]
      description: "Behavior Implementation used by combined BDEF+BIMPL workflow tests (high-level)"
      params:
        class_name: "ZBP_MCP_SHR_I_BDEF"
        description: "Behavior Implementation for ZMCP_SHR_I_BDEF (high-level)"
        behavior_definition: "ZMCP_SHR_I_BDEF"
        implementation_code: |
          CLASS lhc_ZMCP_SHR_I_BDEF DEFINITION INHERITING FROM cl_abap_behavior_handler.
            PRIVATE SECTION.

              METHODS get_instance_authorizations FOR INSTANCE AUTHORIZATION
                IMPORTING keys REQUEST requested_authorizations FOR zmcp_shr_i_bdef RESULT result.

              METHODS get_global_authorizations FOR GLOBAL AUTHORIZATION
                IMPORTING REQUEST requested_authorizations FOR zmcp_shr_i_bdef RESULT result.

