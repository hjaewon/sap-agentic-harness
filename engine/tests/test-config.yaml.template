        @AbapCatalog.dataMaintenance : #RESTRICTED
        define table zmcp_shr_ctabl {
          key client    : abap.clnt not null;
          key chld_id   : abap.char(10) not null;
          parent_id     : abap.char(10) not null;
          fld2          : abap.char(50);
        }

